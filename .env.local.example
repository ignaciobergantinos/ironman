# Copia este archivo a .env.local y rellena con los valores de tu proyecto Supabase
# (Supabase dashboard -> Project Settings -> Data API / API Keys)

NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-publica

# Ruta pública /api/coach: uuid del usuario cuyo entrenamiento se expone en JSON.
# Debe coincidir con el uuid de la policy "coach: public read" en supabase/schema.sql.
# Lo sacas con:  select id, email from auth.users;
COACH_USER_ID=

# intervals.icu (opcional) — Settings → Developer. ATHLETE_ID=0 = atleta autenticado.
INTERVALS_API_KEY=tu-api-key
INTERVALS_ATHLETE_ID=0

# Solo desarrollo local: permite el login por email sin SSO (/api/dev-login).
# NUNCA la pongas en producción; el route ya se bloquea si NODE_ENV=production.
# Supabase Dashboard → Project Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Modo local total: sin Supabase (auth ni datos) ni intervals.icu. Usuario y actividades
# falsos, registro solo en localStorage. Pon =1 para trabajar en local sin ninguna credencial.
# NUNCA la pongas en producción.
NEXT_PUBLIC_LOCAL_MOCK=0
